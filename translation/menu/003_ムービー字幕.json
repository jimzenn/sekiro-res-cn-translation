    {
      "id": 8000051,
      "status": "from_improved",
      "cn": "敌将，田村，已讨之！",
      "en": "General Tamura is no more!",
      "jp": "敵将、田村、討ち取ったり！",
      "cn_improved": "敌将，田村，已讨之！",
      "cn_resurrection": null
    },
    {
      "id": 8000052,
      "status": "from_improved",
      "cn": "苇名众哟，此战，吾等之胜利！",
      "en": "People of Ashina, we are victorious!",
      "jp": "葦名衆よ、この戦、我らの勝利ぞ！",
      "cn_improved": "苇名众哟，此战，吾等之胜利！",
      "cn_resurrection": null
    },
    {
      "id": 8000053,
      "status": "from_improved",
      "cn": "剑圣，苇名一心",
      "en": "Master swordsman, Isshin Ashina...",
      "jp": "剣聖、葦名一心",
      "cn_improved": "剑圣，苇名一心",
      "cn_resurrection": null
    },
    {
      "id": 8000054,
      "status": "from_improved",
      "cn": "盗国之血战",
      "en": "staged a bloody coup and wrested control of the land.",
      "jp": "国盗りの血戦であった",
      "cn_improved": "盗国之血战",
      "cn_resurrection": null
    },
    {
      "id": 8000055,
      "status": "from_improved",
      "cn": "失魂落魄的野狗吗",
      "en": "What's the matter, stray? Nothing left to lose?",
      "jp": "野良犬が、心すら亡くしたか",
      "cn_improved": "失魂落魄的野狗吗",
      "cn_resurrection": null
    },
    {
      "id": 8000056,
      "status": "from_improved",
      "cn": "哦",
      "en": "Well, would you look at that.",
      "jp": "ほう",
      "cn_improved": "哦",
      "cn_resurrection": null
    },
    {
      "id": 8000057,
      "status": "from_improved",
      "cn": "要跟我走吗？你这饿狼",
      "en": "... Fascinating.  Will you join me, starving wolf?",
      "jp": "共にくるか、飢えた狼よ",
      "cn_improved": "要跟我走吗？你这饿狼",
      "cn_resurrection": null
    },
    {
      "id": 8000058,
      "status": "from_improved",
      "cn": "你，说不定能成为老夫的左膀右臂，一名优秀的忍者",
      "en": "Your hunger may beget a fine shinobi. A worthy right hand.",
      "jp": "お前なら、儂の片腕、よい忍びとなるやもしれぬわ",
      "cn_improved": "你，说不定能成为老夫的左膀右臂，一名优秀的忍者",
      "cn_resurrection": null
    },
    {
      "id": 8000059,
      "status": "from_improved",
      "cn": "于是",
      "en": "On that day...",
      "jp": "そして",
      "cn_improved": "于是",
      "cn_resurrection": null
    },
    {
      "id": 8000060,
      "status": "from_improved",
      "cn": "在战场捡回的狼",
      "en": "a young cub was taken from the battlefield.",
      "jp": "戦場で拾われた狼は",
      "cn_improved": "在战场捡回的狼",
      "cn_resurrection": null
    },
    {
      "id": 8000061,
      "status": "from_improved",
      "cn": "历经修行",
      "en": "He trained relentlessly and indeed--",
      "jp": "修行の末",
      "cn_improved": "历经修行",
      "cn_resurrection": null
    },
    {
      "id": 8000062,
      "status": "from_improved",
      "cn": "成为了出类拔萃的忍者",
      "en": "went on to become a master shinobi.",
      "jp": "熟達の忍びとなった",
      "cn_improved": "成为了出类拔萃的忍者",
      "cn_resurrection": null
    },
    {
      "id": 8000063,
      "status": "from_improved",
      "cn": "勿忘忍者戒律",
      "en": "Listen Wolf, you must never forget the Shinobi Code.",
      "jp": "忍びの掟は忘れまいな",
      "cn_improved": "勿忘忍者戒律",
      "cn_resurrection": null
    },
    {
      "id": 8000064,
      "status": "from_improved",
      "cn": "仅次于父母之要人，你要铭记于心",
      "en": "As your father, my word is absolute.  Your master's is a close second.",
      "jp": "親の次に大事なもの、お前の心に刻むがよい",
      "cn_improved": "仅次于父母之要人，你要铭记于心",
      "cn_resurrection": null
    },
    {
      "id": 8000065,
      "status": "from_improved",
      "cn": "从今天起，那就是你的主人",
      "en": "As of today, he is your master.",
      "jp": "あれが、今日からお前の主だ",
      "cn_improved": "从今天起，那就是你的主人",
      "cn_resurrection": null
    },
    {
      "id": 8000066,
      "status": "from_improved",
      "cn": "你要以命相守，如有被掳，必夺还之",
      "en": "Defend him with your life.  If he is taken, bring him back at any cost.",
      "jp": "命を賭して守り、たとえ奪われるとも、必ず取り戻すのだ",
      "cn_improved": "你要以命相守，如有被掳，必夺还之",
      "cn_resurrection": null
    },
    {
      "id": 8000067,
      "status": "from_improved",
      "cn": "明白吗，狼啊...",
      "en": "You understand me, don't you Wolf...",
      "jp": "よいな、狼よ…",
      "cn_improved": "明白吗，狼啊...",
      "cn_resurrection": null
    },
    {
      "id": 8000068,
      "status": "from_improved",
      "cn": "战争，要结束了吗...",
      "en": "Is the war... finally over?",
      "jp": "戦が、終わるのか…",
      "cn_improved": "战争，要结束了吗...",
      "cn_resurrection": null
    },
    {
      "id": 8000069,
